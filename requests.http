Content-Type: application/json

{
  "nombre": "Empresa ACME Actualizada",
  "email": "nuevo@acme.com"
}

###

# ── 16.5 Eliminar un cliente ───────────────────────────────────────────────
DELETE http://localhost:3333/api/clientes/4

