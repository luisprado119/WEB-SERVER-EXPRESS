# ── 16.18 Cambiar el estado de una factura (PATCH parcial) ─────────────────
# PATCH es más correcto que PUT cuando solo se actualiza UN campo.
PATCH http://localhost:3333/api/facturas/F2024002/estado
Content-Type: application/json

{
  "estado": "pagada"
}

