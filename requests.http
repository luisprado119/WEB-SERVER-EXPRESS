# ============================================================================
# SECCIÓN 10: BASE DE DATOS – Consultas a PostgreSQL
# ============================================================================
#
# Express puede conectarse a bases de datos usando drivers de Node.js.
# Para PostgreSQL se usa el módulo 'pg' (node-postgres).
#
# CONCEPTOS CLAVE:
#
# Pool de conexiones:
#   En lugar de abrir/cerrar una conexión por cada consulta, Pool mantiene un
#   grupo de conexiones reutilizables. Esto mejora el rendimiento bajo carga.
#   Se crea UNA SOLA VEZ al iniciar el servidor y se reutiliza en todas las rutas.
#
# pool.query(sql):
#   Ejecuta una consulta SQL y devuelve una Promise.
#   El resultado tiene:
#     result.rows      -> array de objetos con las filas devueltas
#     result.rowCount  -> número de filas afectadas
#
# Patrón async/await + try/catch:
#   El await espera el resultado de la consulta sin bloquear otras peticiones.
#   El catch captura errores de conexión o SQL y devuelve status 500.
#
# CONSULTAS CON PARÁMETROS (evitan SQL Injection):
#   pool.query('SELECT * FROM users WHERE id = $1', [id])
#   Los valores se pasan en un array; pg los escapa de forma segura.
#   NUNCA concatenar valores del usuario directamente en el SQL.

# ---- EJEMPLO 10.a ----
# GET /bdd/test  ->  Test de conexión a la base de datos
#
# Ejecuta: SELECT now() AS fecha
# Verifica que PostgreSQL responde y devuelve la fecha/hora actual del servidor.
# Si hay error de conexión recibirás: { "error": "Error de conexión...", "details": "..." }
# Si la conexión es correcta: { "fecha": "2026-03-13T12:34:56.789Z" }
#
# Úsalo siempre que quieras comprobar si la BDD está activa y accesible.
GET http://localhost:3333/bdd/test

###

# ---- EJEMPLO 10.b ----
# GET /bdd/customers  ->  Listar todos los registros de la tabla 'customers'
#
# Ejecuta: SELECT * FROM customers
# Devuelve un array JSON con TODOS los registros de la tabla.
# Respuesta esperada: [ { customer_id, company_name, contact_name, ... }, ... ]
# Si la tabla está vacía: []
# Si la tabla no existe recibirás un error 500 con el mensaje de PostgreSQL.
#
# NOTA: En una API real añadirías paginación:
#   SELECT * FROM customers LIMIT 20 OFFSET 0
GET http://localhost:3333/bdd/customers

###

# ---- EJEMPLO 10.c ----
# GET /bdd/orders/:cliente  ->  Todos los pedidos de un cliente concreto
#
# Ejecuta: SELECT * FROM orders WHERE customer_id = $1
# El valor de :cliente en la URL se pasa como parámetro $1 al SQL.
#
# CLAVE: parámetros SQL con $1, $2...
#   pool.query('SELECT * FROM orders WHERE customer_id = $1', [req.params.cliente])
#   PostgreSQL sustituye $1 por el valor de forma SEGURA (evita SQL Injection).
#   NUNCA escribir: `WHERE customer_id = '${req.params.cliente}'`
#
# Prueba con distintos customer_id: ALFKI, ANATR, ANTON, AROUT, BERGS...
# Respuesta esperada: [ { order_id, customer_id, order_date, ... }, ... ]
GET http://localhost:3333/bdd/orders/ALFKI

###

# Mismo endpoint, otro cliente
GET http://localhost:3333/bdd/orders/ANTON

###

# ---- EJEMPLO 10.d ----
# GET /bdd/orders/:cliente/:id  ->  Un pedido específico de un cliente
#
# Ejecuta: SELECT * FROM orders WHERE customer_id = $1 AND order_id = $2
# Usa DOS parámetros de ruta (:cliente y :id) para identificar un único registro.
# Ejemplo: ALFKI tiene los pedidos 10643, 10692, 10702, 10835, 10952, 11011
#
# Respuesta esperada: { order_id, customer_id, order_date, shipped_date, ... }
# Si no existe el pedido: { "error": "Pedido no encontrado" }  con status 404
#
# Prueba: cambia el order_id o el cliente para ver el comportamiento
GET http://localhost:3333/bdd/orders/ALFKI/10643

###

# Pedido de otro cliente
GET http://localhost:3333/bdd/orders/ANTON/10365

###

# Pedido inexistente -> devuelve 404 { "error": "Pedido no encontrado" }
# NOTA: order_id es de tipo smallint en PostgreSQL (rango: -32768 a 32767)
#       Usar un número dentro de ese rango pero que no exista en la tabla.
GET http://localhost:3333/bdd/orders/ALFKI/9999

###

###############################################################################
# RESUMEN: BASE DE DATOS CON NODE.JS Y POSTGRESQL
###############################################################################
#
# CONFIGURACIÓN DEL POOL (en app.js):
#   const { Pool } = require('pg')
#   const pool = new Pool({
#     host:     'localhost',
#     port:     5432,         // Puerto estándar de PostgreSQL
#     user:     'postgres',
#     password: 'tu_password',
#     database: 'nombre_db'  // Opcional
#   })
#
# PATRÓN DE RUTA CON BASE DE DATOS:
#   app.get('/recurso', async (req, res) => {
#     try {
#       const resultado = await pool.query('SELECT * FROM tabla')
#       res.json(resultado.rows)
#     } catch (error) {
#       res.status(500).json({ error: error.message })
#     }
#   })
#
# CONSULTAS PARAMETRIZADAS (OBLIGATORIO para datos del usuario):
#   const { rows } = await pool.query(
#     'SELECT * FROM customers WHERE id = $1 AND activo = $2',
#     [req.params.id, true]
#   )
#
# BUENAS PRÁCTICAS:
#   1. Usa SIEMPRE parámetros ($1, $2...) para valores dinámicos
#   2. Nunca concatenes req.params o req.body directamente en el SQL
#   3. Maneja SIEMPRE los errores con try/catch
#   4. Devuelve result.rows (el array), no el objeto QueryResult completo
#   5. En producción usa variables de entorno para las credenciales
#
###############################################################################

###

# ============================================================================
# SECCIÓN 11: BLOCKCHAIN – Consultas a Ethereum con Web3.js
# ============================================================================
#
# Web3.js es la librería estándar para interactuar con la blockchain de Ethereum.
# Permite LEER datos sin coste (sin gas) a través de un proveedor (Infura, Alchemy...).
#
# CONCEPTOS CLAVE:
#
# Wei y Ether:
#   La unidad mínima de Ethereum es el Wei.
#   1 Ether = 10^18 Wei = 1,000,000,000,000,000,000 Wei
#   Web3.utils.fromWei(wei, 'ether') convierte a Ether (más legible)
#
# Nonce (transaction count):
#   Número de transacciones que ha ENVIADO un wallet.
#   Nonce = 0  →  wallet nuevo, nunca ha enviado transacciones
#   Nonce > 0  →  wallet activo, con historial de envíos
#
# Checksummed Address (EIP-55):
#   Ethereum acepta direcciones en minúsculas, pero el estándar EIP-55
#   usa mayúsculas específicas para detectar errores tipográficos.
#   Web3.utils.toChecksumAddress() convierte cualquier dirección al formato correcto.
#
# Promise.all():
#   Para hacer varias llamadas a la blockchain en PARALELO (más eficiente que esperar
#   cada una de forma secuencial), usamos Promise.all([p1, p2, p3]).


# ---- EJEMPLO 11.a ----
# GET /web3/balance/:address  ->  Balance de un wallet en Wei y en ETH
#
# Consulta el saldo de la dirección indicada en la URL.
# Esta dirección es tu primer wallet creado en la práctica.
#
# Respuesta esperada (wallet nuevo sin fondos):
#   {
#     "address": "0xCaB113E18897a870E8489DA9b8EA37fce653dE2D",
#     "balanceWei": "0",
#     "balanceEth": "0"
#   }
GET http://localhost:3333/web3/balance/0xCaB113E18897a870E8489DA9b8EA37fce653dE2D

###

# Puedes consultar cualquier otra dirección pública de Ethereum.
# Por ejemplo, la dirección de Vitalik Buterin (creador de Ethereum):
GET http://localhost:3333/web3/balance/0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045

###

# ---- EJEMPLO 11.b ----
# GET /web3/wallet/:address  ->  Info completa del wallet
#
# Hace tres consultas en PARALELO con Promise.all():
#   1. getBalance()           -> saldo en Wei y ETH
#   2. getTransactionCount()  -> número de transacciones enviadas (nonce)
#   3. getBlockNumber()       -> último bloque de la red (confirma conectividad)
#
# Respuesta esperada:
#   {
#     "address":          "0xCaB113E18897a870E8489DA9b8EA37fce653dE2D",
#     "checksumAddress":  "0xCaB113E18897a870E8489DA9b8EA37fce653dE2D",
#     "balanceWei":       "0",
#     "balanceEth":       "0",
#     "transactionCount": "0",   <- nonce = 0, wallet nuevo
#     "latestBlock":      "...", <- número del bloque actual de Mainnet
#     "network":          "mainnet"
#   }
GET http://localhost:3333/web3/wallet/0xCaB113E18897a870E8489DA9b8EA37fce653dE2D

###

# Info completa de Vitalik Buterin (wallet con mucha actividad)
GET http://localhost:3333/web3/wallet/0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045

###

###

# ---- EJEMPLO 11.c ----
# GET /web3/eth/getblock/:numero  ->  Datos completos de un bloque de Ethereum
#
# Devuelve toda la información del bloque cuyo número se indica en la URL.
# Cada bloque es un "eslabón" de la cadena: contiene transacciones, hash del bloque
# anterior (parentHash), timestamp, minero/validador, y metadatos de gas.
#
# Campos principales de la respuesta:
#   number        -> índice del bloque en la cadena
#   hash          -> identificador único del bloque (SHA-3)
#   parentHash    -> hash del bloque anterior (forma la "cadena")
#   timestamp     -> cuándo fue minado (segundos Unix)
#   miner         -> dirección del validador que creó el bloque
#   transactions  -> array de hashes de las transacciones incluidas
#   gasUsed       -> gas consumido por todas las transacciones del bloque
#   gasLimit      -> gas máximo permitido

# Bloque génesis (el primero de la historia de Ethereum, 30 Jul 2015)
GET http://localhost:3333/web3/eth/getblock/1

###

# El Merge: bloque histórico donde Ethereum pasó de PoW a PoS (15 Sep 2022)
GET http://localhost:3333/web3/eth/getblock/15537394

###

# Un bloque reciente (cámbialo por cualquier número)
GET http://localhost:3333/web3/eth/getblock/24656825

###

# Bloque inexistente -> devuelve 404
GET http://localhost:3333/web3/eth/getblock/999999999

###

###############################################################################
# RESUMEN: BLOCKCHAIN CON NODE.JS Y WEB3.JS
###############################################################################
#
# CONFIGURACIÓN DEL PROVEEDOR (en app.js):
#   const { Web3 } = require('web3')                   // Web3 v4: desestructuración
#   const web3Provider = new Web3('https://mainnet.infura.io/v3/TU_KEY')
#
# LECTURAS (gratuitas, sin gas):
#   const balance = await web3Provider.eth.getBalance(address)
#   const nonce   = await web3Provider.eth.getTransactionCount(address)
#   const block   = await web3Provider.eth.getBlockNumber()
#
# CONVERSIÓN DE UNIDADES:
#   Wei → Ether:  Web3.utils.fromWei(wei, 'ether')
#   Ether → Wei:  Web3.utils.toWei('1.5', 'ether')
#
# CONSULTAS EN PARALELO (más eficiente):
#   const [balance, nonce] = await Promise.all([
#     web3Provider.eth.getBalance(address),
#     web3Provider.eth.getTransactionCount(address)
#   ])
#
# BUENAS PRÁCTICAS:
#   1. Las lecturas (getBalance, etc.) son GRATUITAS, úsalas libremente
#   2. Nunca expongas tu clave privada en el código (solo en .env)
#   3. Valida las direcciones con Web3.utils.isAddress(addr) antes de consultarlas
#   4. Usa toChecksumAddress() para normalizar direcciones recibidas del usuario
#   5. En producción usa variables de entorno para la API KEY de Infura/Alchemy
#
###############################################################################

###

# ============================================================================
# SECCIÓN 13: OBJECT STORAGE – MinIO (compatible con AWS S3)
# ============================================================================
#
# MinIO es un servidor de almacenamiento de objetos compatible con la API de AWS S3.
# Permite guardar y servir ficheros (imágenes, PDFs, vídeos, backups...) de forma escalable.
#
# PARA ARRANCAR EL SERVIDOR MINIO (ejecutar en una terminal PowerShell):
#   $env:MINIO_ROOT_USER="minioadmin"
#   $env:MINIO_ROOT_PASSWORD="minioadmin"
#   .\minio.exe server C:\minio-data --console-address :9001
#
#   API S3:   http://localhost:9000
#   Consola:  http://localhost:9001  <- interfaz web para gestionar buckets visualmente
#
# CONCEPTOS:
#   Bucket  -> contenedor principal (como una carpeta raíz). Nombre en minúsculas.
#   Object  -> cualquier fichero guardado en un bucket.
#   Key     -> nombre del objeto (puede contener "/" para simular subcarpetas).
#
# URL FIRMADA (presigned URL):
#   URL temporal y segura para descargar un fichero directamente desde MinIO.
#   Incluye una firma criptográfica con fecha de expiración.
#   Útil para compartir ficheros privados sin exponerlos permanentemente.


# ---- EJEMPLO 13.a ----
# GET /minio/buckets  ->  Listar todos los buckets existentes
# Respuesta esperada: [] (si no hay ninguno) o [ { name, creationDate }, ... ]
GET http://localhost:3333/minio/buckets

###

# ---- EJEMPLO 13.b ----
# POST /minio/buckets/:bucket  ->  Crear un nuevo bucket
# El nombre del bucket debe estar en minúsculas y sin espacios.
# Si ya existe devuelve 409. Si se crea correctamente devuelve 201.
POST http://localhost:3333/minio/buckets/mis-practicas

###

# Crear otro bucket para imágenes
POST http://localhost:3333/minio/buckets/imagenes-curso

###

# Intentar crear un bucket que ya existe -> devuelve 409
POST http://localhost:3333/minio/buckets/mis-practicas

###

# ---- EJEMPLO 13.c ----
# GET /minio/buckets/:bucket/files  ->  Listar ficheros de un bucket
# Respuesta esperada: [] (vacío) o [ { name, size, lastModified, etag }, ... ]
# etag = hash MD5 del contenido, sirve para detectar cambios en el fichero.
GET http://localhost:3333/minio/buckets/mis-practicas/files

###

# ---- EJEMPLO 13.d ----
# POST /minio/buckets/:bucket/upload  ->  Subir un fichero al bucket
# El fichero debe enviarse en el campo multipart llamado "fichero".
# Prueba desde el formulario en http://localhost:3333/formulario2.html
# o desde el REST Client con el campo file:
POST http://localhost:3333/minio/buckets/mis-practicas/upload
Content-Type: multipart/form-data; boundary=----FormBoundary

------FormBoundary
Content-Disposition: form-data; name="fichero"; filename="test.txt"
Content-Type: text/plain

Contenido de prueba para MinIO - práctica Object Storage
------FormBoundary--

###

# ---- EJEMPLO 13.e ----
# GET /minio/buckets/:bucket/files/:filename/url  ->  URL firmada de descarga
# Genera una URL temporal para descargar el fichero directamente desde MinIO (sin pasar por Express).
# ?expira=N  ->  duración de la URL en segundos (por defecto 3600 = 1 hora)
#
# La URL resultante se puede abrir en cualquier navegador o cliente HTTP.
# Después de que expire, el acceso al fichero será denegado.
GET http://localhost:3333/minio/buckets/mis-practicas/files/test.txt/url

###

# URL con expiración personalizada: 300 segundos (5 minutos)
GET http://localhost:3333/minio/buckets/mis-practicas/files/test.txt/url?expira=300

###

###############################################################################
# RESUMEN: OBJECT STORAGE CON MINIO Y NODE.JS
###############################################################################
#
# CONFIGURACIÓN DEL CLIENTE (en app.js):
#   const Minio = require('minio')
#   const minioClient = new Minio.Client({
#     endPoint: 'localhost', port: 9000,
#     useSSL: false,
#     accessKey: 'minioadmin', secretKey: 'minioadmin'
#   })
#
# OPERACIONES PRINCIPALES:
#   await minioClient.listBuckets()                        -> lista buckets
#   await minioClient.makeBucket('nombre', 'region')       -> crea bucket
#   await minioClient.bucketExists('nombre')               -> ¿existe?
#   minioClient.listObjects('bucket', '', true)            -> stream de objetos
#   await minioClient.putObject('bucket', 'key', buffer, size) -> sube fichero
#   await minioClient.presignedGetObject('bucket', 'key', 3600) -> URL firmada
#   await minioClient.removeObject('bucket', 'key')        -> borra objeto
#
# DIFERENCIA CLAVE CON fs (sistema de ficheros local):
#   fs     -> guarda ficheros en el disco del servidor (no escala, no tiene URLs)
#   MinIO  -> guarda en servicio de objetos, con URLs, políticas y replicación
#             Compatible con AWS S3: cambiar endPoint por tu bucket en la nube
#
# ---- EJEMPLO 13.f ----
# GET /minio/buckets/:bucket/files/:filename  ->  Recuperar / descargar un fichero
#
# Descarga el fichero a través de Express usando streaming (stream.pipe(res)).
# El fichero pasa por el servidor sin cargarse en memoria completo.
#
# DIFERENCIA con presigned URL:
#   Esta ruta:    cliente → Express → MinIO  (el servidor consume ancho de banda)
#   Presigned:    cliente → MinIO directamente (Express solo genera la URL)
#
# Content-Disposition: attachment -> el navegador lo descarga en lugar de mostrarlo
GET http://localhost:3333/minio/buckets/mis-practicas/files/package.json

###

# ---- EJEMPLO 13.g ----
# DELETE /minio/buckets/:bucket/files/:filename/v1
# Eliminar un fichero usando el patrón Promise chaining (.then / .catch)
#
# Patrón:
#   minioClient.removeObject(bucket, filename)
#     .then(() => res.json({ message: 'ok' }))
#     .catch(err => res.status(500).json({ error: err.message }))
#
# Era el estilo estándar antes de async/await (ES2017).
# Funcional pero puede volverse complejo con múltiples operaciones encadenadas.
DELETE http://localhost:3333/minio/buckets/mis-practicas/files/package.json/v1

###

# ---- EJEMPLO 13.h ----
# DELETE /minio/buckets/:bucket/files/:filename
# Eliminar un fichero usando el patrón async / await
#
# Patrón:
#   async (req, res) => {
#     try {
#       await minioClient.removeObject(bucket, filename)
#       res.json({ message: 'ok' })
#     } catch (error) {
#       res.status(500).json({ error: error.message })
#     }
#   }
#
# VENTAJAS sobre .then/.catch:
#   1. Código lineal de arriba a abajo (más fácil de leer)
#   2. Un solo try/catch para todos los pasos
#   3. Stack trace más claro al depurar
#   4. Mejor manejo de variables entre operaciones (sin closures)
DELETE http://localhost:3333/minio/buckets/mis-practicas/files/package.json

###

# BUENAS PRÁCTICAS:
#   1. Un bucket por tipo de contenido (imágenes, documentos, backups...)
#   2. Usa presignedGetObject para compartir ficheros privados temporalmente
#   3. Nunca hagas público un bucket completo en producción
#   4. En producción usa variables de entorno para accessKey y secretKey
#   5. listObjects devuelve un STREAM (no una Promise), usa eventos .on()
#   6. Prefiere async/await sobre .then/.catch para código más legible
#
###############################################################################


###############################################################################
# 14. CORS (Cross-Origin Resource Sharing)
# ─────────────────────────────────────────
# CORS es el mecanismo que controla si el NAVEGADOR permite que una página
# en un origen (dominio:puerto) haga peticiones HTTP a OTRO origen distinto.
#
# CONCEPTOS:
#   Same-Origin Policy → el navegador bloquea por defecto las peticiones
#                        cross-origin (fetch, XHR) para proteger al usuario.
#   CORS               → permite al SERVIDOR relajar esa política añadiendo
#                        la cabecera: Access-Control-Allow-Origin
#   Preflight          → antes de ciertas peticiones (POST con JSON, DELETE...),
#                        el navegador envía un OPTIONS automático para preguntar
#                        si el servidor acepta la petición real.
#
# SERVIDOR CORS DE PRUEBA (app-core.js):
#   Ejecutar en terminal aparte: node app-core.js
#   Escucha en: http://localhost:3345
#   El cliente (cors.html) está en: http://localhost:3333
#   → los dos son ORÍGENES DISTINTOS → se aplica CORS
#
# IMPORTANTE: estas rutas son del servidor app-core.js (puerto 3345),
#             NO del servidor principal app.js (puerto 3333)
###############################################################################

# ── 14.1 Sin CORS ──────────────────────────────────────────────────────────
# El servidor NO devuelve cabeceras CORS.
# Resultado desde el navegador: BLOQUEADO (Network Error)
# Resultado desde curl/REST Client: funciona (curl no aplica CORS)
# LECCIÓN: CORS es una restricción del NAVEGADOR, no del servidor.
GET http://localhost:3345/sin-cors

###

# ── 14.2 CORS abierto (wildcard) ───────────────────────────────────────────
# Access-Control-Allow-Origin: *
# Cualquier origen puede acceder a este recurso.
# Uso: APIs públicas de solo lectura.
# LIMITACIÓN: con wildcard (*) no se puede usar credentials: true
GET http://localhost:3345/cors-abierto

###

# ── 14.3 CORS restringido (origen específico) ──────────────────────────────
# Access-Control-Allow-Origin: http://localhost:3333
# Solo acepta peticiones desde http://localhost:3333
# Uso: tu frontend en producción llamando a tu backend.
GET http://localhost:3345/cors-restringido

###

# ── 14.4 CORS con whitelist dinámica ──────────────────────────────────────
# La función de origen valida si el origen está en la lista permitida.
# Útil cuando tienes múltiples frontends (prod, staging, admin...).
GET http://localhost:3345/cors-whitelist
Origin: http://localhost:3333

###

# ── 14.5 CORS completo (configuración avanzada) ────────────────────────────
# Incluye: origin, methods, allowedHeaders, exposedHeaders, credentials, maxAge
#   methods      → qué verbos HTTP se permiten
#   credentials  → permite enviar cookies/tokens de autenticación
#   maxAge       → segundos que el navegador puede cachear el preflight
GET http://localhost:3345/cors-completo

###

# ── 14.6 CORS con Preflight (POST) ─────────────────────────────────────────
# POST con Content-Type: application/json dispara un preflight OPTIONS.
# El navegador envía primero OPTIONS para verificar si el servidor permite
# la petición. El servidor debe responder con las cabeceras correctas.
POST http://localhost:3345/cors-post
Content-Type: application/json

{
  "accion": "prueba-preflight",
  "descripcion": "Este POST dispara un OPTIONS preflight automáticamente en el navegador"
}

###

# ── 14.7 Verificar cabeceras CORS manualmente ──────────────────────────────
# Simula el preflight que envía el navegador antes de un POST cross-origin.
# El servidor debe responder con Access-Control-Allow-Methods y
# Access-Control-Allow-Headers entre otros.
OPTIONS http://localhost:3345/cors-post
Origin: http://localhost:3333
Access-Control-Request-Method: POST
Access-Control-Request-Headers: Content-Type

###

# ── 14.8 Demo visual interactiva ───────────────────────────────────────────
# Abre cors.html en el navegador para ver visualmente los 6 escenarios:
# http://localhost:3333/cors.html
#
# BUENAS PRÁCTICAS CORS:
#   1. Nunca uses * en producción para rutas con datos sensibles
#   2. Especifica siempre el origen exacto de tu frontend
#   3. Usa whitelist si tienes múltiples frontends legítimos
#   4. maxAge reduce las peticiones OPTIONS y mejora el rendimiento
#   5. credentials: true requiere un origin específico (no puede ser *)
###############################################################################


###############################################################################
# 15. SERVER SIDE PAGES – Motor de plantillas Pug
# ─────────────────────────────────────────────────
# Pug genera HTML dinámico en el servidor antes de enviarlo al cliente.
# El cliente recibe HTML puro, no ve código Pug.
#
# CONFIGURACIÓN en app.js:
#   app.set('view engine', 'pug')
#   app.set('views', './views')
#
# RENDERIZADO:
#   res.render('nombre_plantilla', { variable: valor })
#
# SINTAXIS PUG (sin corchetes, basada en indentación):
#   html
#     head
#       title= titulo          ← variable
#     body
#       h1 Texto estático
#       p Hola, #{nombre}       ← interpolación
#       each item in items      ← bucle
#         li= item
#
# DIFERENCIA con archivos estáticos:
#   /public/index.html  → Express lo sirve del disco tal cual (ESTÁTICO)
#   /t1 (pug)          → Express ejecuta la plantilla + inyecta datos (DINÁMICO)
###############################################################################

# ── 15.1 Plantilla básica con variables ────────────────────────────────────
# Renderiza views/t1.pug con título, mensaje y array de items.
# Devuelve HTML completo generado en el servidor.
GET http://localhost:3333/t1

###

# ── 15.2 Perfil de usuario dinámico ────────────────────────────────────────
# El nombre viene de la URL (parámetro de ruta :nombre).
# Renderiza views/usuario.pug con los datos del usuario.
# Prueba con diferentes nombres:
GET http://localhost:3333/usuario/Luis

###

GET http://localhost:3333/usuario/Ana

###

GET http://localhost:3333/usuario/CodeCrypto

###

# LECCIÓN: con SSP, el mismo template genera páginas completamente distintas
# según los datos que pase el servidor. Es la base de frameworks como EJS, Handlebars, Pug.
###############################################################################


###############################################################################
# 16. ORGANIZACIÓN CON EXPRESS ROUTER
# ─────────────────────────────────────
# Express Router permite separar las rutas en módulos independientes.
#
# ESTRUCTURA:
#   routes/
#     clientes.js  → app.use('/api/clientes',  router)
#     productos.js → app.use('/api/productos', router)
#     facturas.js  → app.use('/api/facturas',  router)
#
# PATRÓN:
#   const router = express.Router()
#   router.get('/', handler)       // → GET /api/clientes
#   router.get('/:id', handler)    // → GET /api/clientes/:id
#   module.exports = { clientes: router }
###############################################################################

# ══ ROUTER CLIENTES (/api/clientes) ═══════════════════════════════════════

# ── 16.1 Listar todos los clientes ─────────────────────────────────────────
GET http://localhost:3333/api/clientes

###

# ── 16.2 Obtener un cliente por ID ─────────────────────────────────────────
GET http://localhost:3333/api/clientes/1

###

GET http://localhost:3333/api/clientes/99
# → 404 Not Found (cliente inexistente)

###

