doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= titulo
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; }
      .card { background: #16213e; border: 1px solid #0f3460; border-top: 4px solid #00d4aa; border-radius: 12px; padding: 2.5rem; max-width: 480px; width: 90%; text-align: center; box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
      .avatar { width: 90px; height: 90px; border-radius: 50%; background: linear-gradient(135deg, #00d4aa, #0f3460); display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 1.2rem; }
      h1 { color: #00d4aa; font-size: 1.5rem; margin-bottom: 0.3rem; }
      .badge { display: inline-block; background: #00d4aa20; color: #00d4aa; border: 1px solid #00d4aa; padding: 0.2rem 0.8rem; border-radius: 20px; font-size: 0.75rem; margin-bottom: 1.5rem; }
      .info { background: #0f3460; border-radius: 8px; padding: 1rem; text-align: left; }
      .info-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #1a2a50; font-size: 0.9rem; }
      .info-row:last-child { border-bottom: none; }
      .label { color: #8090b0; }
      .value { color: #e0e8ff; font-weight: 500; }
      .back { display: inline-block; margin-top: 1.5rem; padding: 0.7rem 1.5rem; background: #00d4aa; color: #1a1a2e; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 0.9rem; }
      .back:hover { background: #00b894; }
  body
    .card
      .avatar #{nombre.charAt(0).toUpperCase()}
      h1= titulo
      span.badge Perfil generado por Pug (SSP)
      .info
        .info-row
          span.label Nombre
          span.value= nombre
        .info-row
          span.label Fecha
          span.value= fecha
        .info-row
          span.label Timestamp ISO
          span.value= horaISO
        .info-row
          span.label Generado con
          span.value Node.js + Express + Pug
      a.back(href='/guia.html') ← Volver a la Guía
