doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= titulo
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; color: #e0e0e0; min-height: 100vh; }
      header { background: linear-gradient(135deg, #0f3460 0%, #16213e 100%); padding: 2rem; border-bottom: 3px solid #00d4aa; }
      header h1 { color: #00d4aa; font-size: 1.8rem; }
      header p  { color: #a0a0c0; margin-top: 0.5rem; }
      main { max-width: 800px; margin: 2rem auto; padding: 0 1.5rem; }
      .badge { display: inline-block; background: #00d4aa; color: #1a1a2e; padding: 0.2rem 0.8rem; border-radius: 20px; font-size: 0.75rem; font-weight: bold; margin-bottom: 1rem; }
      h2 { color: #00d4aa; margin: 1.5rem 0 0.8rem; }
      p  { color: #b0b8d0; line-height: 1.7; }
      ul { list-style: none; padding: 0; }
      ul li { padding: 0.6rem 1rem; margin: 0.4rem 0; background: #16213e; border-left: 3px solid #00d4aa; border-radius: 4px; color: #d0d8f0; }
      ul li::before { content: '✓ '; color: #00d4aa; font-weight: bold; }
      .back { display: inline-block; margin-top: 2rem; padding: 0.7rem 1.5rem; background: #00d4aa; color: #1a1a2e; text-decoration: none; border-radius: 6px; font-weight: bold; }
      .back:hover { background: #00b894; }
  body
    header
      span.badge PUG – SERVER SIDE PAGES
      h1= titulo
      p Motor de plantillas para Node.js + Express
    main
      h2 ¿Qué es Pug?
      p= mensaje
      h2 Características de esta plantilla
      ul
        each item in items
          li= item
      h2 Variables recibidas del servidor
      p Esta plantilla recibió las siguientes variables:
      ul
        li
          strong titulo: 
          | #{titulo}
        li
          strong items: 
          | Array de #{items.length} elementos
      a.back(href='/guia.html') ← Volver a la Guía
